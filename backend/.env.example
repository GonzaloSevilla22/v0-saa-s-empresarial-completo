# Supabase JWT secret (Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=

# PostgreSQL -- usar el pooler de Supabase (puerto 6543, no 5432)
# postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# Upstash Redis
# redis://default:[password]@[host].upstash.io:6379
REDIS_URL=

# Entorno de ejecucion
APP_ENV=development
# Backend URL (exposed to Next.js frontend)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# CORS origin (set to your frontend domain in production)
BACKEND_ALLOWED_ORIGIN=*

SUPABASE_SERVICE_ROLE_KEY=

MERCADOPAGO_WEBHOOK_SECRET=

MERCADOPAGO_ACCESS_TOKEN=